{
  "name": "awesome-ai-tools",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "astro:dev": "bun run css:build && bun run js:build && astro dev",
    "astro:build": "bun run css:build && bun run js:build && astro build",
    "astro:preview": "astro preview",
    "css:build": "tailwindcss -i ./src/input.css -o ./public/css/output.css --minify",
    "css:watch": "tailwindcss -i ./src/input.css -o ./public/css/output.css --watch",
    "js:build": "bun run build.js",
    "build": "bun run astro:build",
    "dev": "bun run astro:dev",
    "dev:js": "bun run build.js",
    "test": "bun test",
    "test:watch": "bun test --watch js/*.test.js",
    "validate:enriched": "bun run scripts/validate-enriched.js"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.5",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "latest",
    "astro": "^6.1.9",
    "tailwindcss": "^4.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@fingerprintjs/fingerprintjs": "^5.1.0",
    "astro-seo": "^1.1.0",
    "html2canvas": "^1.4.1",
    "mdast-util-to-string": "^4.0.0",
    "reading-time": "^1.5.0"
  }
}
