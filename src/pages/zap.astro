---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout
    title="Zap Dashboard | ai.dosa.dev"
    description="Your Zap voting history and analytics on ai.dosa.dev — the curated AI tools directory."
    canonical="https://ai.dosa.dev/zap"
    activeNav="zap"
>
    <div class="max-w-[1400px] mx-auto w-full flex flex-col flex-1 min-h-0 p-8">
        <div class="max-w-2xl">
            <h2 class="text-2xl font-semibold mb-6 flex items-center gap-3">
                <svg class="w-6 h-6 text-[#F2C040]" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                </svg>
                Zap Dashboard
            </h2>
            <div class="border border-[#222] bg-white/5 rounded-md p-6">
                <p class="text-[#a3a3a3]">Zap management and analytics are coming soon.</p>
            </div>
        </div>
    </div>
</DashboardLayout>
