---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout
    title="Help & Support | ai.dosa.dev"
    description="Help documentation and FAQs for ai.dosa.dev — the curated AI tools directory."
    canonical="https://ai.dosa.dev/help"
    activeNav="help"
>
    <div class="max-w-[1400px] mx-auto w-full flex flex-col flex-1 min-h-0 p-8">
        <div class="max-w-2xl">
            <h2 class="text-2xl font-semibold mb-6 flex items-center gap-3">
                <svg class="w-6 h-6 text-[#a3a3a3]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
                Help &amp; Support
            </h2>
            <div class="border border-[#222] bg-white/5 rounded-md p-6">
                <p class="text-[#a3a3a3] mb-4">Help documentation and FAQs are coming soon.</p>
                
                <h3 class="text-xl font-medium text-white mb-3 mt-8">Semantic Search API</h3>
                <p class="text-[#a3a3a3] mb-4">ai.dosa.dev provides a dynamic Semantic Search API intended for programmatic consumption by AI agents and LLM-powered assistants.</p>
                <div class="bg-[#111] p-4 rounded-md border border-[#333] font-mono text-sm mb-4">
                    GET https://ai.dosa.dev/api/search
                </div>
                
                <h4 class="font-medium text-white mb-2">Query Parameters</h4>
                <ul class="list-disc pl-5 text-[#a3a3a3] mb-4 space-y-2">
                    <li><code class="bg-[#222] px-1 rounded text-[#e5e5e5]">q</code> (required) - The natural language text query to search for. Semantic search will match intent across tool descriptions, verdicts, and use cases.</li>
                    <li><code class="bg-[#222] px-1 rounded text-[#e5e5e5]">price</code> (optional) - Filter by pricing model (e.g., <code>free</code>, <code>freemium</code>).</li>
                    <li><code class="bg-[#222] px-1 rounded text-[#e5e5e5]">category</code> (optional) - Filter by tool tag/category.</li>
                </ul>

                <h4 class="font-medium text-white mb-2">Example</h4>
                <div class="bg-[#111] p-4 rounded-md border border-[#333] font-mono text-sm overflow-x-auto text-[#a3a3a3]">
                    curl "https://ai.dosa.dev/api/search?q=summarizing%20video%20content&price=freemium"
                </div>
            </div>
        </div>
    </div>
</DashboardLayout>
