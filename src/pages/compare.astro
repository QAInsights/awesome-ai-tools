---
/**
 * Compare page — side-by-side tool comparison.
 * 
 * The compareGrid is populated client-side by dist/compare.js which reads
 * the `?tools=slug1,slug2` query params and fetches enriched-tools.json.
 * This matches the exact behaviour of the original compare.html.
 */
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout
    title="Compare Tools | ai.dosa.dev"
    description="Compare AI coding tools side-by-side — features, pricing, and verdict. Powered by ai.dosa.dev."
    canonical="https://ai.dosa.dev/compare"
    activeNav="compare"
>
    <div class="max-w-7xl mx-auto py-12 px-6 w-full flex-1 overflow-y-auto min-h-0">
        <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-2xl sm:text-3xl font-semibold text-white mb-2">Compare Tools</h1>
                <p class="text-[#a3a3a3]">See how your selected tools stack up against each other.</p>
            </div>
            <a href="/"
                class="self-start sm:self-auto px-4 py-2 border border-[#333] rounded transition-all duration-300 hover:border-[#a78bfa] hover:bg-gradient-to-r hover:from-[#a78bfa] hover:via-[#22d3ee] hover:to-[#a78bfa] hover:bg-[length:200%_auto] hover:bg-clip-text hover:text-transparent text-[#a3a3a3] hover:text-transparent">
                &larr; Back to registry
            </a>
        </div>

        <div id="compareGrid" class="flex flex-col md:flex-row gap-6 w-full">
            <!-- Populated client-side by /dist/compare.js via ?tools= query params -->
        </div>
    </div>

    <!-- Compare page needs its own bundle (separate from app.js) -->
    <script type="module" src="/dist/compare.js"></script>
</DashboardLayout>
