---
import { getCollection } from 'astro:content';
import DashboardLayout from '../../layouts/DashboardLayout.astro';

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection('blog', ({ data }) => {
    return data.draft !== true;
  });
  const posts = allPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return paginate(posts, { pageSize: 6 });
}

const { page } = Astro.props;
---

<DashboardLayout
  title={`Blog | ai.dosa.dev${page.currentPage > 1 ? ` (Page ${page.currentPage})` : ''}`}
  description="Read the latest news, tutorials, and deep dives into AI tools for developers."
  canonical={`https://ai.dosa.dev/blog${page.currentPage > 1 ? `/${page.currentPage}` : ''}`}
  activeNav="blog"
>
  <div class="max-w-[1400px] mx-auto w-full flex flex-col flex-1 min-h-full p-6 md:p-8">
    <div class="max-w-3xl flex flex-col flex-1">
      <div class="mb-10">
        <h2 class="text-2xl font-semibold mb-2 flex items-center gap-3">
            <svg class="w-6 h-6 text-[#a3a3a3]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
            </svg>
            AI Tools Blog
        </h2>
        <p class="text-[#a3a3a3]">Insights, updates, and comparisons on the best AI coding tools.</p>
      </div>

      <div class="space-y-6">
        {page.data.map((post) => (
          <article class="bg-white/[0.02] border border-[#222] rounded-lg overflow-hidden hover:border-[#444] transition-all group">
            <a href={`/blog/${post.id}`} class="flex flex-col md:flex-row h-full">
              {/* Image Section */}
              <div class="w-full md:w-[200px] h-[160px] md:h-auto shrink-0 relative overflow-hidden bg-[#111]">
                <img 
                  src={post.data.image || '/images/blog-placeholder.png'} 
                  alt={post.data.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </div>

              {/* Content Section */}
              <div class="flex-1 p-6 flex flex-col justify-between">
                <div>
                  <div class="flex items-center space-x-2 text-xs text-[#737373] mb-3 font-mono">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('en-us', {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric',
                      })}
                    </time>
                    <span>•</span>
                    <span>{post.data.author}</span>
                  </div>
                  <h3 class="text-xl font-semibold text-white group-hover:text-[#22d3ee] transition-colors mb-2">
                    {post.data.title}
                  </h3>
                  <p class="text-[#a3a3a3] text-[15px] leading-relaxed mb-4 line-clamp-2">
                    {post.data.description}
                  </p>
                </div>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="inline-flex items-center px-2 py-0.5 rounded border border-[#333] text-xs font-mono bg-white/[0.03] text-[#a3a3a3]">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
      
      {page.lastPage > 1 && (
        <div class="mt-12 flex items-center justify-between border-t border-[#222] pt-6">
          {page.url.prev ? (
            <a href={page.url.prev} class="inline-flex items-center justify-center py-2 px-4 bg-white/5 text-white text-sm font-medium border border-[#222] rounded-md transition-all hover:bg-white/10 hover:-translate-y-px">
              &larr; Newer Posts
            </a>
          ) : (
            <div></div>
          )}
          
          <div class="text-sm font-mono text-[#737373]">
            Page {page.currentPage} of {page.lastPage}
          </div>
          
          {page.url.next ? (
            <a href={page.url.next} class="inline-flex items-center justify-center py-2 px-4 bg-white/5 text-white text-sm font-medium border border-[#222] rounded-md transition-all hover:bg-white/10 hover:-translate-y-px">
              Older Posts &rarr;
            </a>
          ) : (
            <div></div>
          )}
        </div>
      )}
      
      <footer class="pt-12 pb-6 text-center mt-auto">
        <span class="font-mono text-xs text-[#525252]">© {new Date().getFullYear()} dosa.dev</span>
      </footer>
    </div>
  </div>
</DashboardLayout>
