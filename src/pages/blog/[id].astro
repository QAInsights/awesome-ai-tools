---
import { getCollection, render } from 'astro:content';
import DashboardLayout from '../../layouts/DashboardLayout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { id: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(entry);
---

<DashboardLayout
  title={`${entry.data.title} | ai.dosa.dev`}
  description={entry.data.description}
  canonical={`https://ai.dosa.dev/blog/${entry.id}`}
  activeNav="blog"
>
  <div class="max-w-[1400px] mx-auto w-full flex flex-col flex-1 min-h-full p-6 md:p-8">
    <div class="max-w-3xl flex flex-col flex-1">
      <div class="mb-8">
        <a href="/blog" class="text-[#737373] hover:text-white transition-colors flex items-center text-sm font-mono tracking-wide w-fit">
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Blog
        </a>
      </div>

      <article>
        <header class="mb-10 text-left">
          <h1 class="text-3xl sm:text-4xl font-semibold text-white tracking-tight mb-4">
            {entry.data.title}
          </h1>
          <div class="flex flex-wrap items-center gap-3 text-sm text-[#737373] font-mono">
            <time datetime={entry.data.pubDate.toISOString()}>
              {entry.data.pubDate.toLocaleDateString('en-us', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <span>•</span>
            <span>{entry.data.author}</span>
            {remarkPluginFrontmatter && remarkPluginFrontmatter.readingTime && (
                <>
                <span>•</span>
                <span>{remarkPluginFrontmatter.readingTime}</span>
                </>
            )}
          </div>
          {entry.data.tags && entry.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-6">
              {entry.data.tags.map((tag) => (
                <span class="inline-flex items-center px-2 py-0.5 rounded border border-[#333] text-xs font-mono bg-white/[0.03] text-[#a3a3a3]">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <div class="prose prose-invert prose-zinc max-w-none prose-headings:font-semibold prose-a:text-[#22d3ee] hover:prose-a:text-[#67e8f9] prose-a:no-underline hover:prose-a:underline prose-code:text-[#a78bfa] prose-pre:bg-[#0a0a0a] prose-pre:border prose-pre:border-[#222] prose-img:rounded-lg prose-img:border prose-img:border-[#222] prose-hr:border-[#222]">
          <Content />
        </div>
      </article>
      
      <footer class="pt-12 pb-6 text-center border-t border-[#222] mt-auto">
        <span class="font-mono text-xs text-[#525252]">© {new Date().getFullYear()} dosa.dev</span>
      </footer>
    </div>
  </div>
</DashboardLayout>
