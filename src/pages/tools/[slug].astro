---
/**
 * Dynamic tool detail page — [slug].astro
 *
 * Replaces:
 *   - scripts/generate-tool-pages.js  (build-time page generator)
 *   - src/tool-template.html          (template)
 *   - js/shell.js                     (runtime sidebar injection)
 *   - js/tool-detail.js               (runtime data hydration)
 *   - js/tool-cache.js                (localStorage cache for enriched data)
 *
 * All 108 tool pages are now generated from this single file via getStaticPaths().
 * Seed + enriched data are embedded at build time — no client-side fetch needed.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getAllTools, type Tool } from '../../lib/tools';

export async function getStaticPaths() {
    const tools = getAllTools();
    return tools.map(tool => ({
        params: { slug: tool.slug },
        props: { tool },
    }));
}

interface Props {
    tool: Tool;
}

const { tool } = Astro.props;
const { enriched } = tool;

// Prefer enriched data, fall back to seed
const displayName = enriched?.name ?? tool.name;
const displayCompany = enriched?.company ?? tool.company;
const displayDescription = enriched?.description ?? tool.notes;

// Meta description (truncated to 155 chars)
function truncate(str: string, max: number): string {
    const s = String(str ?? '').replace(/\s+/g, ' ').trim();
    if (s.length <= max) return s;
    return s.slice(0, max - 1).trimEnd() + '…';
}

const descMeta = truncate(displayDescription, 155);

const keywords = [
    tool.name,
    tool.company,
    tool.categoryClean,
    tool.categoryShort,
    'AI coding',
    'developer tools',
].filter(Boolean).join(', ');

// JSON-LD structured data
const jsonLd = JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "SoftwareApplication",
            "@id": `https://ai.dosa.dev/tools/${tool.slug}#app`,
            "name": displayName,
            "url": tool.url || `https://ai.dosa.dev/tools/${tool.slug}`,
            "description": displayDescription,
            "applicationCategory": "DeveloperApplication",
            "operatingSystem": "Any",
            "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
            "isPartOf": { "@type": "WebSite", "@id": "https://ai.dosa.dev/#website" }
        },
        {
            "@type": "BreadcrumbList",
            "itemListElement": [
                { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ai.dosa.dev" },
                { "@type": "ListItem", "position": 2, "name": tool.categoryClean, "item": `https://ai.dosa.dev/#${tool.slug}` },
                { "@type": "ListItem", "position": 3, "name": displayName, "item": `https://ai.dosa.dev/tools/${tool.slug}` }
            ]
        }
    ]
});

// Pricing human-readable label
function humanizePricing(val?: string): string {
    if (!val) return '';
    const map: Record<string, string> = { free: 'Free', freemium: 'Freemium', paid: 'Paid', open_source: 'Open Source', oss: 'Open Source', enterprise: 'Enterprise' };
    return map[val.toLowerCase()] ?? (val.charAt(0).toUpperCase() + val.slice(1));
}

// Date formatter
function formatDate(iso?: string): string {
    if (!iso) return '';
    try {
        const d = new Date(iso);
        if (isNaN(d.getTime())) return iso;
        return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    } catch {
        return iso;
    }
}

function escapeHtml(str: string): string {
    return String(str ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}
---

<BaseLayout
    title={`${displayName} — ${displayCompany} | ai.dosa.dev`}
    description={descMeta}
    keywords={keywords}
    canonical={`https://ai.dosa.dev/tools/${tool.slug}`}
    ogTitle={`${displayName} — ${displayCompany} | ai.dosa.dev`}
    ogDescription={descMeta}
    ogType="article"
    twitterTitle={`${displayName} — ${displayCompany} | ai.dosa.dev`}
    twitterDescription={descMeta}
    jsonLd={jsonLd}
>
    <slot name="head">
        <style>
            .td-section { padding: 20px 0; border-top: 1px solid #222; }
            .td-section:first-of-type { border-top: none; }
            .td-section-label { font-family: 'JetBrains Mono', monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: #525252; margin-bottom: 14px; }
            .td-card { background: #0d0d0d; border: 1px solid #222; border-radius: 10px; padding: 18px; transition: border-color 0.2s; }
            .td-card:hover { border-color: #333; }
            .td-verdict { border-left: 3px solid; border-image: linear-gradient(180deg, #a78bfa, #22d3ee) 1; padding: 14px 18px; background: linear-gradient(90deg, rgba(167,139,250,0.04), transparent); font-size: 16px; line-height: 1.7; color: #d4d4d4; font-style: italic; }
        </style>
    </slot>

    <div class="flex h-[100dvh] overflow-hidden">
        <Sidebar variant="tool" />

        <main class="flex-1 flex flex-col h-full bg-black min-w-0 relative overflow-y-auto">
            <!-- Mobile Header -->
            <div class="md:hidden flex items-center justify-between p-4 border-b border-[#222] bg-[#0a0a0a] shrink-0 z-10 sticky top-0">
                <div class="flex items-center gap-3">
                    <button id="openSidebarMobile" aria-label="Open sidebar menu" class="text-[#a3a3a3] hover:text-white transition-colors p-1 rounded-md hover:bg-white/5">
                        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                    </button>
                    <div class="flex items-center gap-2 min-w-0">
                        <img src="/images/icons/favicon-32x32.png" alt="logo" class="w-6 h-6 rounded-full" />
                        <span class="text-[17px] font-semibold tracking-wide text-white leading-none truncate">{displayName}</span>
                    </div>
                </div>
            </div>

            <!-- Desktop Sidebar Toggle -->
            <div id="desktopToggleContainer" class="hidden absolute top-[14px] left-4 z-20 transition-opacity duration-300">
                <button id="openSidebarDesktop" aria-label="Open sidebar" class="text-[#a3a3a3] hover:text-white p-1.5 bg-[#0a0a0a] border border-[#222] rounded-md shadow-sm transition-all hover:bg-white/5 backdrop-blur-sm" title="Open sidebar">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line></svg>
                </button>
            </div>

            <div class="max-w-[1000px] mx-auto w-full flex flex-col flex-1 p-4 md:p-8 gap-6">
                <!-- Breadcrumb -->
                <nav aria-label="Breadcrumb" class="font-mono text-[12px] text-[#737373] tracking-wide flex items-center gap-2 flex-wrap">
                    <a href="/" class="hover:text-white transition-colors">Home</a>
                    <span>/</span>
                    <span class="text-[#a3a3a3]">{tool.categoryClean}</span>
                    <span>/</span>
                    <span class="text-white">{displayName}</span>
                </nav>

                <!-- Hero Header -->
                <header class="flex flex-col gap-4 pb-4 border-b border-[#222]">
                    <div class="flex items-start justify-between gap-4 flex-wrap">
                        <div class="min-w-0">
                            <h1 class="text-[32px] md:text-[40px] font-semibold tracking-tight leading-tight bg-gradient-to-r from-white via-[#e5e5e5] to-white bg-clip-text text-transparent mb-2">
                                {displayName}
                            </h1>
                            <div class="flex items-center gap-3 flex-wrap">
                                <span class="font-mono text-[14px] text-[#a3a3a3] uppercase tracking-wide">{displayCompany}</span>
                                <span class="text-[#333]">·</span>
                                <span class="inline-block px-3 py-1 border border-[#222] rounded-full bg-white/5 font-mono text-[12px] text-[#a3a3a3] tracking-wide">{tool.categoryClean}</span>
                            </div>
                        </div>
                        <a href={tool.url} target="_blank" rel="noopener noreferrer"
                            class="inline-flex items-center gap-2 py-2.5 px-5 bg-white text-black text-sm font-semibold rounded-md transition-all duration-200 hover:bg-gray-200 hover:-translate-y-px shrink-0"
                            aria-label={`Visit ${displayName} website`}>
                            Visit site
                            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                        </a>
                    </div>
                    <p class="text-[17px] leading-relaxed text-[#d4d4d4] max-w-[72ch]">{displayDescription}</p>
                </header>

                <!-- Enriched Content Sections (build-time rendered) -->
                <div class="flex flex-col gap-6">

                    {!enriched && (
                        <div class="td-card flex items-start gap-3 border-dashed">
                            <svg class="w-5 h-5 text-[#737373] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            <div class="text-[14px] text-[#a3a3a3] leading-relaxed">
                                <div class="text-white font-medium mb-0.5">Enriched details coming soon</div>
                                We're still gathering pricing, key features, and reviewer notes for this tool. In the meantime, visit the official site for more.
                            </div>
                        </div>
                    )}

                    {enriched?.keyFeatures && enriched.keyFeatures.length > 0 && (
                        <section class="td-section">
                            <div class="td-section-label">Key Features</div>
                            <ul class="flex flex-col gap-3">
                                {enriched.keyFeatures.map(f => (
                                    <li class="flex items-start gap-3">
                                        <svg class="w-5 h-5 shrink-0 text-[#a78bfa] mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="20 6 9 17 4 12"></polyline>
                                        </svg>
                                        <span class="text-[15px] leading-relaxed text-[#d4d4d4]">{f}</span>
                                    </li>
                                ))}
                            </ul>
                        </section>
                    )}

                    {(enriched?.bestFor || enriched?.notIdealFor) && (
                        <section class="td-section">
                            <div class="td-section-label">Who It's For</div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="td-card">
                                    <div class="font-mono text-[11px] uppercase text-[#4ade80] tracking-wide mb-2">&#10003; Best For</div>
                                    <p class="text-[15px] leading-relaxed text-[#d4d4d4]">{enriched.bestFor ?? '—'}</p>
                                </div>
                                <div class="td-card">
                                    <div class="font-mono text-[11px] uppercase text-[#f87171] tracking-wide mb-2">&#10007; Not Ideal For</div>
                                    <p class="text-[15px] leading-relaxed text-[#d4d4d4]">{enriched.notIdealFor ?? '—'}</p>
                                </div>
                            </div>
                        </section>
                    )}

                    {(enriched?.pricing || enriched?.pricingDetail) && (
                        <section class="td-section">
                            <div class="td-section-label">Pricing</div>
                            <div class="td-card">
                                <div class="flex items-center gap-3 mb-2">
                                    <span class="inline-block px-3 py-1 bg-[#a78bfa]/10 border border-[#a78bfa]/30 rounded-full font-mono text-[12px] text-[#c4b5fd] tracking-wide">
                                        {humanizePricing(enriched.pricing)}
                                    </span>
                                </div>
                                {enriched.pricingDetail && (
                                    <p class="text-[15px] leading-relaxed text-[#d4d4d4]">{enriched.pricingDetail}</p>
                                )}
                            </div>
                        </section>
                    )}

                    {enriched?.recentUpdates && (
                        <section class="td-section">
                            <div class="td-section-label">Recent Updates</div>
                            <div class="td-card"><p class="text-[15px] leading-relaxed text-[#d4d4d4]">{enriched.recentUpdates}</p></div>
                        </section>
                    )}

                    {enriched?.verdict && (
                        <section class="td-section">
                            <div class="td-section-label">Verdict</div>
                            <blockquote class="td-verdict">{enriched.verdict}</blockquote>
                        </section>
                    )}

                    {enriched?.tags && enriched.tags.length > 0 && (
                        <section class="td-section">
                            <div class="td-section-label">Tags</div>
                            <div class="flex flex-wrap gap-2">
                                {enriched.tags.map(tag => (
                                    <span class="inline-block px-3 py-1 border border-[#222] rounded-full bg-white/5 font-mono text-[12px] text-[#a3a3a3] tracking-wide">{tag}</span>
                                ))}
                            </div>
                        </section>
                    )}

                    {enriched?.lastUpdated && (
                        <div class="font-mono text-[11px] text-[#525252] tracking-wide py-4">
                            Last updated: {formatDate(enriched.lastUpdated)}
                        </div>
                    )}

                    <div class="py-6">
                        <a href="/" class="inline-flex items-center gap-2 text-[14px] text-[#737373] hover:text-white transition-colors">
                            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                            Back to directory
                        </a>
                    </div>

                    <div class="td-section" style="padding-top: 0;">
                        <div class="flex items-start gap-3 py-4 px-4 border border-[#222] rounded-lg bg-white/[0.02]">
                            <svg class="w-5 h-5 text-[#737373] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <line x1="12" y1="8" x2="12" y2="12"></line>
                                <line x1="12" y1="16" x2="12.01" y2="16"></line>
                            </svg>
                            <p class="text-[13px] text-[#737373] leading-relaxed">
                                Content on this page is AI-generated. Please verify details with the vendor's website for accuracy.
                            </p>
                        </div>
                    </div>

                </div>
            </div>
        </main>
    </div>

    <!-- Client scripts for auth + sidebar toggle (shared with all pages) -->
    <script src="/dist/app.js" type="module" defer></script>
</BaseLayout>
